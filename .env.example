# MongoDB
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DATABASE_NAME=webshop

# JWT (tối thiểu 32 ký tự)
JWT_SECRET=WebShop-Super-Secret-Key-Change-In-Production-32chars!
JWT_ISSUER=WebShop
JWT_AUDIENCE=WebShop

# Admin đầu tiên (chỉ tạo khi chưa có Admin trong DB)
BOOTSTRAP_ADMIN_EMAIL=admin@glowbeauty.vn
BOOTSTRAP_ADMIN_PASSWORD=your-secure-password-here

# CORS (frontend dev)
CORS_ORIGINS=http://localhost:5173
